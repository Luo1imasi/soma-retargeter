            "r_body" : "torso_link",
            "t_weight" : 0.7,
            "r_weight" : 0.7
        },
        "LeftArm": {
            "t_body" : "left_arm_roll_link",
            "r_body" : "left_arm_roll_link",
            "t_weight" : 1.5,
            "r_weight" : 0.15
        },
        "LeftForeArm": {
            "t_body" : "left_elbow_pitch_link",
            "r_body" : "left_elbow_pitch_link",
